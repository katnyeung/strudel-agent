# LLM Provider — "anthropic" | "openai" | "ollama" | "openrouter"
LLM_PROVIDER=anthropic

# API Key (not needed for ollama)
LLM_API_KEY=sk-ant-api03-xxxxx

# Model to use
LLM_MODEL=claude-sonnet-4-5-20250929

# Base URL (only for ollama/custom providers)
LLM_BASE_URL=

# Server port
PORT=8080

# Skills directory (relative to project root)
SKILLS_PATH=./skills
