# LLM Provider — "anthropic" | "gemini" | "openai" | "xai" | "ollama" | "openrouter"
LLM_PROVIDER=gemini

# API Key (not needed for ollama)
LLM_API_KEY=AIzaSy...

# Model to use
LLM_MODEL=gemini-2.0-flash

# Base URL (only for ollama/custom providers)
LLM_BASE_URL=

# Server port
PORT=8080

# Skills directory (relative to project root)
SKILLS_PATH=./skills

# Neon database (optional — event logging disabled if unset)
NEON_DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Review LLM (optional — falls back to main LLM_* if unset)
# Use a smarter/longer-context model for analysis review
REVIEW_LLM_PROVIDER=
REVIEW_LLM_API_KEY=
REVIEW_LLM_MODEL=
REVIEW_LLM_BASE_URL=

# Neo4j Aura (optional — graph memory disabled if unset)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=                  # leave empty for default database

# ElevenLabs TTS (vocal combo system — disabled if unset)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=             # optional, defaults to Rachel
