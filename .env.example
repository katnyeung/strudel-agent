# LLM Provider — "anthropic" | "gemini" | "openai" | "ollama" | "openrouter"
LLM_PROVIDER=gemini

# API Key (not needed for ollama)
LLM_API_KEY=AIzaSy...

# Model to use
LLM_MODEL=gemini-2.0-flash

# Base URL (only for ollama/custom providers)
LLM_BASE_URL=

# Server port
PORT=8080

# Skills directory (relative to project root)
SKILLS_PATH=./skills
